# =====================================================================
# Torre de Controle - variáveis de ambiente do serviço (EnvironmentFile)
# Copiar para /etc/salome/torre.env no servidor e ajustar os valores.
# NUNCA versionar o arquivo com segredos reais.
# =====================================================================

# Liga o módulo Torre neste processo (datasource RW + sync + API + painel).
SALOME_TORRE_ENABLED=true

# Porta própria da Torre (separada do serviço financeiro 8787 / export).
SALOME_SERVER_PORT=8789

# Banco próprio da Torre (MySQL read-write, separado do legado).
SALOME_TORRE_DB_URL=jdbc:mysql://127.0.0.1:3306/salome_torre
SALOME_TORRE_DB_USERNAME=salome_torre
SALOME_TORRE_DB_PASSWORD=trocar-por-segredo-forte

# Segredo do JWT (>= 32 caracteres). Gerar único por ambiente.
SALOME_TORRE_JWT_SECRET=trocar-por-segredo-com-32-caracteres-ou-mais
SALOME_TORRE_JWT_EXP_MIN=720

# Sincronizador do legado (cron Spring).
SALOME_TORRE_SYNC_CRON=0 */5 * * * *

# Leitura do legado (somente leitura) - reaproveita o banco legado existente.
SALOME_LEGACY_DB_ENABLED=true
SALOME_LEGACY_DB_URL=jdbc:mysql://HOST_LEGADO:3306/BASE_LEGADO
SALOME_LEGACY_DB_USERNAME=leitor
SALOME_LEGACY_DB_PASSWORD=trocar

# Fotos de ocorrência: diretório persistente (fora do /target). JPG/PNG/WEBP até 10MB.
SALOME_TORRE_FOTOS_DIR=/var/lib/salome/torre/fotos
SALOME_TORRE_FOTOS_MAX=10MB

# Export de manifesto DESLIGADO no serviço da Torre (já roda no serviço dedicado).
SALOME_MANIFESTO_EXPORT_ENABLED=false
